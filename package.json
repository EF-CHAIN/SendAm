{
  "name": "sendam",
  "version": "1.0.0",
  "license": "MIT",
  "description": "SendAm - WhatsApp-based Stellar payment MVP",
  "homepage": "https://send-am-web.vercel.app/",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:landing": "npm run dev --workspace=apps/landing",
    "dev:admin": "npm run dev --workspace=apps/admin",
    "dev:chat-sim": "npm run start --workspace=apps/chat-sim",
    "dev": "npm run dev:api & npm run dev:landing & npm run dev:admin",
    "build:landing": "npm run build --workspace=apps/landing",
    "build:admin": "npm run build --workspace=apps/admin",
    "lint": "npm run lint --workspace=apps/api && npm run lint --workspace=apps/landing && npm run lint --workspace=apps/admin",
    "test": "npm run test --workspace=apps/api",
    "install:all": "npm install"
  }
}
