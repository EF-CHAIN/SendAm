PORT=3002
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/sendam
# Comma-separated origins allowed to call the REST API (admin + landing apps).
# Required in production; when empty in dev, all origins are allowed.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# 64-char hex (32 bytes). Generate your own — never reuse this placeholder.
# Used for aes-256-gcm encryption of wallet secret keys.
# openssl rand -hex 32
ENCRYPTION_KEY=
# Admin dashboard auth. ADMIN_PASSWORD is the login password; JWT_SECRET signs
# session tokens (use a long random value: openssl rand -hex 32). Both are
# required — the API will not start without them.
ADMIN_PASSWORD=
JWT_SECRET=
# Optional: admin session lifetime in hours (default 12).
ADMIN_SESSION_TTL_HOURS=12
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_id_here
WHATSAPP_VERIFY_TOKEN=your_verify_token
# Meta App Secret — verifies the X-Hub-Signature-256 header on webhook POSTs.
# Required in production; without it, forged webhook events are rejected.
WHATSAPP_APP_SECRET=
# Per-user transfer guardrails (XLM). Defaults: 1000 / 5000 / 50.
MAX_SEND_AMOUNT=1000
DAILY_SEND_LIMIT=5000
MAX_SENDS_PER_DAY=50
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
