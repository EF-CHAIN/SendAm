PORT=3002
NODE_ENV=development
DATABASE_URL=postgresql://USER:PASSWORD@HOST/sendam?sslmode=require
# Comma-separated origins allowed to call the REST API (admin + landing apps).
# Required in production; when empty in dev, all origins are allowed.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# 64-char hex (32 bytes). Generate your own — never reuse this placeholder.
# Used for aes-256-gcm encryption of wallet secret keys.
# openssl rand -hex 32
ENCRYPTION_KEY=
# Admin dashboard auth. ADMIN_PASSWORD is the login password; JWT_SECRET signs
# session tokens (use a long random value: openssl rand -hex 32). Both are
# required — the API will not start without them.
ADMIN_PASSWORD=
JWT_SECRET=
# Optional: admin session lifetime in hours (default 12).
ADMIN_SESSION_TTL_HOURS=12
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_id_here
WHATSAPP_VERIFY_TOKEN=your_verify_token
# Meta App Secret — verifies the X-Hub-Signature-256 header on webhook POSTs.
# Required in production; without it, forged webhook events are rejected.
WHATSAPP_APP_SECRET=
# Per-user transfer guardrails (XLM). Defaults: 1000 / 5000 / 50.
MAX_SEND_AMOUNT=1000
DAILY_SEND_LIMIT=5000
MAX_SENDS_PER_DAY=50
# Request rate limits (PostgreSQL-backed, shared across instances).
# REST API: max requests per IP per window. WhatsApp bot: max messages per
# sender per window.
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=100
BOT_RATE_WINDOW_SEC=60
BOT_RATE_MAX=20
REDIS_URL=
UPSTASH_REDIS_URL=
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
# The REST wallet API (/api/wallet/*) is unauthenticated — the phone number in
# the request body is the only identity. It's disabled in production unless you
# set this to "true". Outside production it defaults to enabled for local tests.
ENABLE_WALLET_REST_API=false
# Paymaster (optional) — a privately-run relayer that sponsors Lisk gas fees.
# Not part of this repo. Leaving these unset simply disables sponsorship; Lisk
# sends still work self-funded either way. Not yet wired into the live send
# flow — see paymaster.service.js. PAYMASTER_SERVICE_SECRET is the HMAC shared
# secret for the X-Sendam-Signature calling contract; PAYMASTER_API_KEY is the
# deprecated legacy bearer token.
PAYMASTER_SERVICE_URL=
PAYMASTER_SERVICE_SECRET=
PAYMASTER_API_KEY=

# Privately-operated service clients (all optional, all default OFF). Each
# needs its ENABLE_* flag set to "true" AND a URL + HMAC secret; anything
# less disables the client and the feature degrades gracefully — the public
# repo runs fully standalone without any of these.
# sendam-ai: intent decoding fallback when the regex parser can't classify a
# message. The regex parser stays primary either way.
ENABLE_AI_INTENT=false
AI_SERVICE_URL=
AI_SERVICE_SECRET=
# Policy service (transaction limits/risk) — when off, the local KYC-tier
# logic in compliance.service.js is the documented fallback.
ENABLE_POLICY_SERVICE=false
POLICY_SERVICE_URL=
POLICY_SERVICE_SECRET=
# sendam-ns: resolves sigil-prefixed global names (@ada / ada*sendam.app) in
# the recipient flow. Saved contacts always win; bare names never hit NS.
ENABLE_NS_RESOLUTION=false
NS_SERVICE_URL=
NS_SERVICE_SECRET=
NS_DOMAIN=sendam.app
# sendam-settlement: ledger/quoting client stub — wired nowhere yet, zero
# behavior change while off.
ENABLE_SETTLEMENT=false
SETTLEMENT_SERVICE_URL=
SETTLEMENT_SERVICE_SECRET=
# NGN price display (src/services/priceOracle.service.js) — shows balances in
# Naira alongside the native asset. Swappable: official CBN vs. parallel-market
# rate is a product decision, not resolved here. Default provider
# (open.er-api.com) needs no API key; FX_API_KEY is only used if you swap in a
# provider that requires one.
FX_PROVIDER=exchangerate_api
FX_API_KEY=

# Direct custody: each user gets a Stellar and a Lisk wallet, keys generated
# and encrypted (ENCRYPTION_KEY above) in this database. Lisk L2 testnet
# (Lisk Sepolia). Official RPC is rate-limited; an alternative is
# https://lisk-sepolia.drpc.org if you hit limits during development. Unlike
# Stellar's Friendbot, there is no auto-fund API for Lisk Sepolia — new
# wallets must be funded manually via a faucet (see README).
LISK_CHAIN_ID=4202
LISK_RPC_URL=https://rpc.sepolia-api.lisk.com
LISK_EXPLORER_URL=https://sepolia-blockscout.lisk.com

# Pricing and FX.
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
COINGECKO_API_KEY=
EXCHANGERATE_API_KEY=

# KYC, AML, and PIN verification.
KYC_PROVIDER=smileid
SMILE_ID_PARTNER_ID=
SMILE_ID_API_KEY=
DOJAH_APP_ID=
DOJAH_SECRET_KEY=
PIN_PEPPER=
TIER_1_DAILY_LIMIT=50000
TIER_1_SINGLE_LIMIT=20000
TIER_2_DAILY_LIMIT=500000
TIER_2_SINGLE_LIMIT=200000
TIER_3_DAILY_LIMIT=5000000
TIER_3_SINGLE_LIMIT=1000000

# Voice payments.
VOICE_PROVIDER=deepgram
DEEPGRAM_API_KEY=
WHISPER_API_KEY=
OPENAI_API_KEY=

# Cloudflare R2 for media/receipt storage.
CLOUDFLARE_R2_ENDPOINT=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
